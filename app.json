{
  "expo": {
    "name": "바로응급실",
    "slug": "BaroER",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "baroer",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E53935"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mrsure.baroer",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "응급 상황 설명을 위해 마이크 권한이 필요합니다.",
        "NSSpeechRecognitionUsageDescription": "음성을 텍스트로 변환하기 위해 음성 인식 권한이 필요합니다."
      }
    },
    "android": {
      "package": "com.mrsure.baroer",
      "config": {
        "googleMaps": {
          "apiKey": "" 
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "응급 상황 설명을 위해 마이크 권한이 필요합니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
