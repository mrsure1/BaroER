# 바로응급실 (BaroER) - 환경변수 설정
# 이 파일을 .env로 복사한 후 실제 키를 입력하세요.
# .env 파일은 .gitignore에 포함되어 커밋되지 않습니다.

# 공공데이터포털 API 키 (국립중앙의료원 응급의료기관 정보)
# 발급: https://data.go.kr → "국립중앙의료원_전국 응급의료기관 정보 조회 서비스" 활용신청

EXPO_PUBLIC_DATA_SERVICE_KEY=e6e5a6b21891f23bcdf5953b54dc89a335ddfff7fbf2be2a335c39c70c0960bb
EXPO_PUBLIC_DATA_ER_BASE_URL=http://apis.data.go.kr/B552657/ErmctInfoInqireService
# 실시간 응급실 가용병상 정보
PUBLIC_DATA_ER_OPERATION=getEmrrmRltmUsefulSckbdInfoInqire

# 카카오 개발자 앱 키 (카카오맵 + 카카오 로그인)
