# 바로응급실 (BaroER · Web App) - 환경변수 템플릿
#
# 이 파일을 .env.local 로 복사한 후 실제 키를 입력하세요.
# .env.local 은 .gitignore 에 포함되어 커밋되지 않습니다.
#
# 변수명 규칙
#   NEXT_PUBLIC_*   : 브라우저(클라이언트)에 노출됨. JS SDK 로드·공개 설정값 전용.
#   (접두사 없음)    : Next.js 서버 전용. API Route / Server Action 에서만 접근 가능.
# -----------------------------------------------------------------------------


# =============================================================================
# 1. 공공데이터포털 (응급의료 실시간 데이터)
#    발급: https://data.go.kr → 국립중앙의료원_전국 응급의료기관 정보 조회 서비스
#    ⚠️ 반드시 서버 전용 — 브라우저 노출 금지
# =============================================================================
DATA_SERVICE_KEY=
DATA_ER_BASE_URL=http://apis.data.go.kr/B552657/ErmctInfoInqireService
DATA_ER_OPERATION=getEmrrmRltmUsefulSckbdInfoInqire


# =============================================================================
# 2. 네이버 클라우드 플랫폼 (Maps / Directions)
#    발급: https://www.ncloud.com → Console → AI·NAVER API → Maps
#    - Web 서비스 URL 에 로컬(localhost:3000) 및 운영 도메인 등록 필수
# =============================================================================
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=


# =============================================================================
# 3. Kakao Developers (카카오 로그인)
#    발급: https://developers.kakao.com → 내 애플리케이션
#    - Web 플랫폼 사이트 도메인 등록, Redirect URI 등록 필수
# =============================================================================
NEXT_PUBLIC_KAKAO_JS_KEY=
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=


# =============================================================================
# 4. Firebase (인증 + Firestore) - Web SDK 설정
#    발급: https://console.firebase.google.com → 프로젝트 설정 → 웹 앱 등록
# =============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=


# =============================================================================
# 5. Firebase Admin SDK (서버 전용)
#    Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
# =============================================================================
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# 개행은 \n 으로 이스케이프해 한 줄로 보관
FIREBASE_ADMIN_PRIVATE_KEY=


# =============================================================================
# 6. Google OAuth (웹 클라이언트 ID)
#    발급: https://console.cloud.google.com → APIs & Services → Credentials
#    - "승인된 자바스크립트 원본" 및 "승인된 리디렉션 URI" 등록 필수
# =============================================================================
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=


# =============================================================================
# 7. (선택) Twilio - 자동 전화 확인 기능 (MVP 이후)
# =============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
